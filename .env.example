# Logging Configuration
LOG_LEVEL=INFO

# RSS Feeds (Comma-separated URLs)
RSS_FEEDS=https://kubernetes.io/feed.xml,https://aws.amazon.com/blogs/aws/feed/

# Email Configuration (SMTP)
# Note: For free email sending, you can use Gmail SMTP with a Google App Password,
# or free tiers from transactional email providers like SendGrid or Mailerlite.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=your_email@gmail.com
EMAIL_TO=recipient_email@gmail.com

# Gemini API Key
# Google AI Studio offers a free tier for Gemini API keys.
# Get yours at https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key
